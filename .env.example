# === Configuración de Agente_Trabajos ===
# Copia este archivo a .env y ajusta valores locales
# Nunca subas .env a GitHub

# Delay para scraping HTML genérico
REQUEST_DELAY_MIN=1.2
REQUEST_DELAY_MAX=3.0

# Delay para APIs estructuradas
API_DELAY_MIN=0.0
API_DELAY_MAX=0.10

# Timeout por request
REQUEST_TIMEOUT=20

# Límite de páginas Workday por empresa
# 0 = sin límite
WORKDAY_MAX_PAGES=25

# Headers / comportamiento HTTP
HTTP_ACCEPT_LANGUAGE=en-US,en;q=0.9,es;q=0.8

# Perfil opcional futuro
USER_PROFILE=

# Base de datos Postgres opcional para NorthHound
# Ejemplo:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/northhound
DATABASE_URL=

# Cache local de scraping por empresa
SCRAPE_CACHE_ENABLED=1
SCRAPE_CACHE_TTL_HOURS=8

# Corridas programadas
SCHEDULED_PROFILES=Finance
SCHEDULE_SKIP_IF_RAN_TODAY=0
