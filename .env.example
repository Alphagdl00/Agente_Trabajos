# === Configuración de Agente_Trabajos ===
# Copia este archivo a .env y ajusta valores locales
# Nunca subas .env a GitHub

# Delay entre peticiones para scraping responsable
REQUEST_DELAY_MIN=1.2
REQUEST_DELAY_MAX=3.0

# Timeout por request
REQUEST_TIMEOUT=20

# Headers / comportamiento HTTP
HTTP_ACCEPT_LANGUAGE=en-US,en;q=0.9,es;q=0.8

# Perfil opcional futuro
USER_PROFILE=